rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function hasPrivilegedDiscussionRole() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['volunteer', 'ngo', 'admin'];
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isNotChangingRoleFields() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'role',
        'isVolunteer',
        'isVerified',
        'volunteerApplicationId',
        'volunteerApprovedAt',
        'volunteerRejectedAt',
        'volunteerRevokedAt'
      ]);
    }

    function isSafeUserProfileCreate(userId) {
      return isOwner(userId)
        && !request.resource.data.keys().hasAny(['isVolunteer', 'isVerified'])
        && (
          !request.resource.data.keys().hasAny(['role'])
          || request.resource.data.role == 'supporter'
        );
    }

    function canUseAudience(audience) {
      // Missing audience on legacy rooms = public
      return audience == null
        || audience == 'all'
        || (audience == 'restricted' && hasPrivilegedDiscussionRole());
    }

    function canUseGroupVisibility(visibilityScope) {
      // Missing visibilityScope on legacy groups = public
      return visibilityScope == null
        || visibilityScope == 'all'
        || (visibilityScope == 'volunteers' && hasPrivilegedDiscussionRole());
    }

    function isRoomParticipant(room) {
      return signedIn()
        && 'participants' in room
        && request.auth.uid in room.participants;
    }

    function isGroupMember(group) {
      return signedIn()
        && 'members' in group
        && request.auth.uid in group.members;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isAdmin() || isSafeUserProfileCreate(userId);
      allow update: if isAdmin() || (isOwner(userId) && isNotChangingRoleFields());
      allow delete: if isAdmin();
    }

    match /volunteers/{volunteerId} {
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update, delete: if isAdmin();
    }

    match /sponsors/{sponsorId} {
      allow read, update, delete: if isAdmin();
      allow create: if signedIn();
    }

    match /viewToHelp/{itemId} {
      allow read, write: if isAdmin();
    }

    match /logistics/{itemId} {
      allow read, write: if isAdmin();
    }

    // NGO registration applications (Feed → NGO Register form).
    // Collection name must match client: "ngoRegister" (not Ngos / ngos).
    // Auth users: create own pending app + read own docs only.
    // Admins: full read/update/delete (approve/reject). Not public.
    match /ngoRegister/{applicationId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update, delete: if isAdmin();
    }

    // NGO catalog (capital N). Legacy lowercase "ngos" is not used for new data.
    function isNgoOwner(ngoId) {
      return signedIn()
        && exists(/databases/$(database)/documents/Ngos/$(ngoId))
        && get(/databases/$(database)/documents/Ngos/$(ngoId)).data.ownerUid == request.auth.uid;
    }

    match /Ngos/{ngoId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      // Admin full update; NGO owner may update profile fields; donors may only bump received
      allow update: if isAdmin()
        || (signedIn()
          && resource.data.ownerUid == request.auth.uid
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['ownerUid', 'verified']))
        || (signedIn()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['received']));
    }

    // Shared donation ledger for NGO Portal + Admin review
    match /donations/{donationId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.donorId == request.auth.uid)
        || (signedIn() && isNgoOwner(resource.data.ngoId));

      allow create: if signedIn()
        && request.resource.data.keys().hasAll([
          'ngoId', 'ngoName', 'donorName', 'type', 'status', 'source', 'timestamp'
        ])
        && request.resource.data.type in ['money', 'food', 'clothes']
        && request.resource.data.status in [
          'pending', 'under_review', 'approved', 'rejected', 'refunded', 'action_required'
        ]
        && request.resource.data.source in ['credits', 'individual', 'in_kind'];

      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /users/{userId}/donations/{donationId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update, delete: if isAdmin();
    }

    match /verificationRequests/{requestId} {
      allow read: if isAdmin() || isOwner(requestId);
      allow create: if isOwner(requestId);
      allow update, delete: if isAdmin();
    }

    match /campaigns/{campaignId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Social Impact Feed posts (do not confuse with CMS collection cmsPosts)
    match /posts/{postId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.isDiscussionEnabled is bool
        && request.resource.data.discussionAudience in ['all', 'restricted'];
      allow update: if signedIn();
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;

      match /comments/{commentId} {
        allow read: if true;
        allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
      }
    }

    // Blog & News CMS (Admin-managed content)
    // Public may only read published documents; admins have full CRUD.
    match /cmsPosts/{postId} {
      allow read: if resource.data.published == true || isAdmin();

      allow create: if isAdmin()
        && request.resource.data.keys().hasAll([
          'title', 'slug', 'excerpt', 'content', 'image', 'author',
          'category', 'published', 'featured', 'createdAt', 'updatedAt'
        ])
        && request.resource.data.category in ['blog', 'news']
        && request.resource.data.published is bool
        && request.resource.data.featured is bool
        && request.resource.data.title is string
        && request.resource.data.slug is string;

      allow update: if isAdmin()
        && request.resource.data.category in ['blog', 'news']
        && request.resource.data.published is bool
        && request.resource.data.featured is bool;

      allow delete: if isAdmin();
    }

    match /discussions/{discussionId} {
      // List: only rooms you already belong to.
      // (Must not also require audience here — queries cannot filter on audience,
      // and "rules are not filters" would deny the whole participants query.)
      allow list: if signedIn() && isRoomParticipant(resource.data);

      // Get: members always; non-members may open an invite link by room id
      // when the room audience allows their role.
      allow get: if signedIn() && (
        isRoomParticipant(resource.data)
        || canUseAudience(resource.data.audience)
      );

      allow create: if signedIn()
        && request.resource.data.postId == discussionId
        && request.resource.data.audience in ['all', 'restricted']
        && canUseAudience(request.resource.data.audience)
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 1
        && request.resource.data.participants.hasOnly([request.auth.uid]);

      allow update: if signedIn() && (
        // Join via invite: add yourself only
        (
          canUseAudience(resource.data.audience)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'participants',
            'participantRoles',
            'updatedAt'
          ])
          && request.resource.data.participants.hasAll(resource.data.participants)
          && request.resource.data.participants.hasAny([request.auth.uid])
          && request.resource.data.participants.size() <= resource.data.participants.size() + 1
        )
        // Participants may update last-message metadata
        || (
          isRoomParticipant(resource.data)
          && canUseAudience(resource.data.audience)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'updatedAt',
            'lastMessage',
            'lastMessageAt',
            'lastMessageSenderId',
            'lastMessageSenderName'
          ])
        )
        // Creator / post owner / admin may edit room details
        || (
          (
            resource.data.creatorId == request.auth.uid
            || resource.data.postOwnerId == request.auth.uid
            || isAdmin()
          )
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'groupName',
            'postTitle',
            'description',
            'postImageUrl',
            'updatedAt'
          ])
        )
      );

      match /messages/{messageId} {
        allow read: if isRoomParticipant(get(/databases/$(database)/documents/discussions/$(discussionId)).data)
          && canUseAudience(get(/databases/$(database)/documents/discussions/$(discussionId)).data.audience);

        allow create: if signedIn()
          && request.resource.data.senderId == request.auth.uid
          && isRoomParticipant(get(/databases/$(database)/documents/discussions/$(discussionId)).data)
          && canUseAudience(get(/databases/$(database)/documents/discussions/$(discussionId)).data.audience);
      }
    }

    // Invite token → groupId mapping so join links work without a collection
    // query that security rules would reject for non-privileged users.
    match /groupInvites/{token} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.keys().hasAll(['groupId', 'createdBy'])
        && request.resource.data.groupId is string
        && (
          request.resource.data.createdBy == request.auth.uid
          || (
            exists(/databases/$(database)/documents/groups/$(request.resource.data.groupId))
            && request.auth.uid in get(/databases/$(database)/documents/groups/$(request.resource.data.groupId)).data.admins
          )
        );
      allow delete: if signedIn()
        && (
          resource.data.createdBy == request.auth.uid
          || isAdmin()
          || (
            exists(/databases/$(database)/documents/groups/$(resource.data.groupId))
            && request.auth.uid in get(/databases/$(database)/documents/groups/$(resource.data.groupId)).data.admins
          )
        );
      allow update: if false;
    }

    match /groups/{groupId} {
      // List:
      // - members array-contains query (isGroupMember always true for results)
      // - legacy inviteToken (+ visibilityScope) query for join links
      //   (canUseGroupVisibility must hold for every possible result)
      allow list: if signedIn() && (
        isGroupMember(resource.data)
        || canUseGroupVisibility(resource.data.visibilityScope)
      );

      // Get: members always; non-members may load a group when visibility allows
      // (needed after resolving invite token → groupId).
      allow get: if signedIn()
        && (
          isGroupMember(resource.data)
          || canUseGroupVisibility(resource.data.visibilityScope)
        );

      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.groupName is string
        && request.resource.data.visibilityScope in ['all', 'volunteers']
        && canUseGroupVisibility(request.resource.data.visibilityScope)
        && request.resource.data.members is list
        && request.resource.data.admins is list
        && request.resource.data.members.size() == 1
        && request.resource.data.admins.size() == 1
        && request.resource.data.members.hasOnly([request.auth.uid])
        && request.resource.data.admins.hasOnly([request.auth.uid]);

      allow update: if signedIn() && (
        // Admins may manage the group (name, pic, members, token, etc.)
        (
          request.auth.uid in resource.data.admins
        )
        // Members may bump last-message fields while chatting
        || (
          isGroupMember(resource.data)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'lastMessage',
            'lastMessageAt',
            'lastMessageSenderId',
            'lastMessageSenderName',
            'updatedAt'
          ])
        )
        // Join via invite: add yourself only
        || (
          canUseGroupVisibility(resource.data.visibilityScope)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'updatedAt'])
          && request.resource.data.members.hasAll(resource.data.members)
          && request.resource.data.members.hasAny([request.auth.uid])
          && request.resource.data.members.size() <= resource.data.members.size() + 1
        )
        // Leave group
        || (
          isGroupMember(resource.data)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'admins', 'updatedAt'])
          && !(request.auth.uid in request.resource.data.members)
        )
      );

      match /messages/{messageId} {
        allow read: if isGroupMember(get(/databases/$(database)/documents/groups/$(groupId)).data);

        allow create: if signedIn()
          && request.resource.data.senderId == request.auth.uid
          && isGroupMember(get(/databases/$(database)/documents/groups/$(groupId)).data);
      }
    }
  }
}
